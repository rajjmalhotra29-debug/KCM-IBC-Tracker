# Copy to .env and fill in. Everything works WITHOUT these (rules-only, demo unlock).

# --- Access model ---
# open      = completely free: every opportunity AND every client match visible, no login.
# freemium  = matches locked behind a paid login.
ACCESS_MODE=open

# --- Security (CHANGE in production) ---
SECRET_KEY=replace-with-a-long-random-string

# --- AI matching (optional). Add a key to switch on the AI ranker. ---
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-8

# --- IBC source site (default: IBBI public announcements) ---
SOURCE_URL=https://www.ibbi.gov.in/en/public-announcement
SOURCE_ADAPTER=ibbi

# --- Payments (optional). Leave blank for demo-unlock mode. ---
PAYMENTS_ENABLED=false
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
SUBSCRIPTION_PRICE_INR=4999

# --- Database (default SQLite). For the shared server use Postgres, e.g.:
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/ibc
